# Salin ke .env.local dan isi. JANGAN commit .env.local.

NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Supabase (Tahap 9) — buat proyek di supabase.com (free tier)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Midtrans (Tahap 10) — sandbox: dashboard.sandbox.midtrans.com
MIDTRANS_SERVER_KEY=
MIDTRANS_CLIENT_KEY=
MIDTRANS_IS_PRODUCTION=false

# Resend (Tahap 10) — notifikasi email
RESEND_API_KEY=
NOTIFY_EMAIL_TO=

# Cloudflare Turnstile (Tahap 9) — anti-spam form publik
TURNSTILE_SECRET_KEY=
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
